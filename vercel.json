{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "valadares-xi.vercel.app" }],
      "destination": "https://valadares.app.br/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/jogar", "destination": "/play.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/ranking", "destination": "/ranking.html" },
    { "source": "/reset", "destination": "/reset.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/jogar",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
